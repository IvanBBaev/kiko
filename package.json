{
  "name": "kiko",
  "version": "0.1.0",
  "private": true,
  "description": "AI news aggregation backend: collects AI news, synthesizes them with Claude into site posts and LinkedIn-ready posts.",
  "license": "MIT",
  "author": "Ivan Baev <ivanbbaev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IvanBBaev/kiko.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts | pino-pretty",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--import=tsx node --test \"src/**/*.test.ts\"",
    "test:coverage": "NODE_OPTIONS=--import=tsx c8 -r text -r lcov --check-coverage --statements 85 --lines 85 --branches 80 --functions 88 node --test \"src/**/*.test.ts\"",
    "check": "npm run build && npm run typecheck && npm run lint && npm run format:check && npm run test:coverage",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pipeline": "tsx src/cli/run-pipeline.ts",
    "ingest": "tsx src/cli/ingest.ts",
    "db:backup": "tsx src/cli/backup.ts",
    "eval": "tsx src/cli/eval.ts",
    "sources": "tsx src/cli/sources.ts",
    "sources:seed": "tsx src/cli/sources.ts seed",
    "og:font": "node scripts/build-og-font.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@resvg/resvg-js": "^2.6.2",
    "better-sqlite3": "^12.10.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "rss-parser": "^3.13.0",
    "satori": "^0.26.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "c8": "^11.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "mermaid": "^11.16.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
