# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Model used for synthesis and LinkedIn generation (default: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8
# Thinking/output effort: low | medium | high | max (default: high)
LLM_EFFORT=high
# Hard cap on output tokens per LLM call, thinking included (default: 16000)
LLM_MAX_OUTPUT_TOKENS=16000

# --- Server ---
PORT=3000
# Optional: when set, POST endpoints require "Authorization: Bearer <token>"
#API_TOKEN=change-me
# Optional: comma-separated allowed CORS origins (default: any origin)
#CORS_ORIGINS=https://example.com,https://www.example.com
# Max requests per minute per client IP (default: 120)
#RATE_LIMIT_MAX=120
# Trust X-Forwarded-* headers — enable only when behind a reverse proxy so the
# rate limiter keys on the real client IP, not the proxy's (default: false)
#TRUST_PROXY=true

# --- Database ---
DB_PATH=./data/kiko.db

# --- Pipeline ---
# Cron expression for the scheduled pipeline run (default: 07:00 every day)
PIPELINE_CRON=0 7 * * *
# Optional IANA timezone for the cron schedule (default: server-local)
#PIPELINE_TZ=Europe/Sofia
PIPELINE_SCHEDULE_ENABLED=true
# Ignore feed items older than N days (default: 3)
MAX_ITEM_AGE_DAYS=3
# Max news items fed into one digest (default: 15)
MAX_ITEMS_PER_DIGEST=15
# Skip the run (save tokens) if fewer than N new items (default: 3)
MIN_ITEMS_PER_DIGEST=3
# Trim each item's summary to N chars before sending to the LLM (default: 400)
ITEM_SUMMARY_MAX_CHARS=400

# --- Output ---
# Base language of generated posts: en | bg | ... (fallback for both channels)
POSTS_LANGUAGE=en
# Per-channel overrides (e.g. bg site + en LinkedIn)
#SITE_LANGUAGE=bg
#LINKEDIN_LANGUAGE=en
# AI-content disclosure surfaced on the API (aiDisclosure) and the RSS feed.
# Always present; override the wording/localization here.
#AI_DISCLOSURE=AI-generated from cited sources and reviewed before publishing.

# --- Integrations / ops ---
# When set, run failures and published posts are POSTed here as JSON events
#WEBHOOK_URL=https://example.com/hooks/kiko
# Public site base URL — used for links in /feed.xml
#PUBLIC_SITE_URL=https://example.com
# Run on boot if the last run is older than N hours; 0 disables (default: 26)
#CATCH_UP_HOURS=26
# pino log level: trace|debug|info|warn|error (default: info)
#LOG_LEVEL=info
# Anthropic client tuning (defaults: 600000 ms, 3 retries)
#LLM_TIMEOUT_MS=600000
#LLM_MAX_RETRIES=3
